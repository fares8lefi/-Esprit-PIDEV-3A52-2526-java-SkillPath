<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<HBox xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="Controllers.course.CourseListController"
      prefHeight="900.0" prefWidth="1440.0" 
      style="-fx-background-color: #0f172a;"
      stylesheets="@../../../FrontOffice/user/auth/style.css">

    <children>
        <!-- Sidebar -->
        <fx:include fx:id="sideBar" source="../Admin/SideBar.fxml" />

        <!-- Main Content -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" HBox.hgrow="ALWAYS">
            <content>
                <VBox spacing="30.0">
                    <padding><Insets bottom="40.0" left="50.0" right="50.0" top="40.0" /></padding>
                    <children>
                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Label text="Gestion des" textFill="WHITE">
                                                    <font><Font name="System Bold" size="32.0" /></font>
                                                </Label>
                                                <Label text="Cours" textFill="#8b5cf6">
                                                    <font><Font name="System Bold" size="32.0" /></font>
                                                </Label>
                                            </children>
                                        </HBox>
                                        <Label text="Administrez les contenus pédagogiques de SkillPath." textFill="#94a3b8" />
                                    </children>
                                </VBox>
                                <Button fx:id="btnRefresh" onAction="#handleRefresh" styleClass="btn-secondary" text="🔄 Actualiser" />
                            </children>
                        </HBox>

                        <HBox spacing="30.0">
                            <children>
                                <!-- Table Section -->
                                <VBox spacing="20.0" styleClass="glass-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <TableView fx:id="courseTable" prefHeight="500.0" style="-fx-background-color: transparent;">
                                            <columns>
                                                <TableColumn fx:id="colTitle" text="Titre" prefWidth="200.0" />
                                                <TableColumn fx:id="colLevel" text="Niveau" prefWidth="100.0" />
                                                <TableColumn fx:id="colCategory" text="Catégorie" prefWidth="150.0" />
                                                <TableColumn fx:id="colCreatedAt" text="Date de création" prefWidth="150.0" />
                                                <TableColumn fx:id="colActions" text="Actions" prefWidth="150.0" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>

                                <!-- Form Section -->
                                <VBox prefWidth="400.0" spacing="20.0" styleClass="glass-card">
                                    <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                                    <children>
                                        <Label text="Détails du Cours" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                                        
                                        <VBox spacing="8.0">
                                            <Label text="TITRE DU COURS" styleClass="form-label" />
                                            <TextField fx:id="txtTitle" styleClass="form-input" promptText="Ex: Programmation Java" />
                                        </VBox>

                                        <VBox spacing="8.0">
                                            <Label text="DESCRIPTION" styleClass="form-label" />
                                            <TextArea fx:id="txtDescription" styleClass="form-input" prefHeight="100.0" promptText="Décrivez le contenu..." wrapText="true" />
                                        </VBox>

                                        <HBox spacing="15.0">
                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                <Label text="NIVEAU" styleClass="form-label" />
                                                <ComboBox fx:id="comboLevel" styleClass="form-input" maxWidth="Infinity" />
                                            </VBox>
                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                <Label text="CATÉGORIE" styleClass="form-label" />
                                                <TextField fx:id="txtCategory" styleClass="form-input" promptText="Ex: Tech" />
                                            </VBox>
                                        </HBox>

                                        <VBox spacing="8.0">
                                            <Label text="IMAGE URL" styleClass="form-label" />
                                            <TextField fx:id="txtImage" styleClass="form-input" promptText="https://..." />
                                        </VBox>

                                        <VBox spacing="15.0">
                                            <Button fx:id="btnSave" onAction="#handleSave" styleClass="btn-primary" maxWidth="Infinity" text="Enregistrer" />
                                            <Button fx:id="btnClear" onAction="#handleClear" styleClass="btn-secondary" maxWidth="Infinity" text="Vider les champs" />
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</HBox>
