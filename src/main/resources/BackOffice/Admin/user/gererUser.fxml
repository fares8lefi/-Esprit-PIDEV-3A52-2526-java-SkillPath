<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<HBox prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #0f172a;" stylesheets="@../../../FrontOffice/user/auth/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.user.admin.GererUserController">
    <children>
        <!-- SIDEBAR -->
        <fx:include fx:id="sideBar" source="../SideBar.fxml" />

        <!-- MAIN CONTENT -->
        <VBox HBox.hgrow="ALWAYS" spacing="30.0" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>
            <children>
                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <HBox spacing="10.0">
                            <Label text="Annuaire des" textFill="WHITE">
                                <font><Font name="System Bold" size="32.0" /></font>
                            </Label>
                            <Label text="Membres" textFill="#8b5cf6">
                                <font><Font name="System Bold" size="32.0" /></font>
                            </Label>
                        </HBox>
                        <Label text="Consultez et gérez les comptes de la plateforme." textFill="#94a3b8" />
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="15.0">
                        <TextField fx:id="searchField" promptText="Rechercher par nom..." style="-fx-background-color: rgba(255,255,255,0.05); -fx-text-fill: white; -fx-padding: 12 20; -fx-background-radius: 20; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 20;" prefWidth="250.0" />
                        <Button styleClass="btn-secondary" text="Rechercher" onAction="#handleSearch" />
                        <Button styleClass="btn-secondary" text="Actualiser" onAction="#handleRefresh" />
                        <Button styleClass="btn-primary" text="+ Ajouter un Membre" onAction="#handleAddUser" />
                    </HBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                     <Label fx:id="lblTotalUsers" style="-fx-font-weight: bold; -fx-font-size: 14;" text="Total: 0 utilisateurs" textFill="#94a3b8" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Label text="Trier par :" textFill="#94a3b8" style="-fx-font-size: 13; -fx-font-weight: bold;" />
                     <ComboBox fx:id="comboTri" onAction="#handleSort" prefWidth="180.0" style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 2; -fx-text-fill: white; -fx-cursor: hand;" />
                </HBox>

                <!-- LIST CONTAINER -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="usersContainer" hgap="25.0" vgap="25.0" style="-fx-background-color: transparent; -fx-padding: 10;">
                            <!-- Les cartes utilisateurs seront injectées ici -->
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</HBox>

