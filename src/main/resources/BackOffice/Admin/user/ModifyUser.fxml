<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefWidth="400.0" spacing="25.0" style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e293b); -fx-padding: 40;" stylesheets="@../../../FrontOffice/user/auth/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.user.admin.ModifyUserController">

    <!-- HEADER -->
    <VBox alignment="CENTER" spacing="5.0">
        <Label text="Modifier l'Utilisateur" textFill="WHITE">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Label fx:id="lblEmail" text="user@email.com" textFill="#94a3b8">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
    </VBox>

    <!-- FORM FIELDS -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" hbarPolicy="NEVER">
        <VBox spacing="20.0" style="-fx-background-radius: 20; -fx-padding: 25; -fx-border-radius: 20; -fx-border-color: rgba(255,255,255,0.1); -fx-border-width: 1; -fx-background-color: rgba(30, 41, 59, 0.7);">
            
            <!-- Nom d'utilisateur -->
            <VBox spacing="8.0">
                <Label text="Nom d'utilisateur :" textFill="#cbd5e1" style="-fx-font-weight: bold;" />
                <TextField fx:id="tfUsername" promptText="Saisissez le nom" style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12; -fx-text-fill: white;" />
            </VBox>

            <!-- Rôle -->
            <VBox spacing="8.0">
                <Label text="Rôle attribué :" textFill="#cbd5e1" style="-fx-font-weight: bold;" />
                <ComboBox fx:id="comboRole" maxWidth="1.7976931348623157E308" promptText="Sélectionnez un rôle" style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 5; -fx-text-fill: white;" />
            </VBox>

            <!-- Statut -->
            <VBox spacing="8.0">
                <Label text="Statut du compte :" textFill="#cbd5e1" style="-fx-font-weight: bold;" />
                <ComboBox fx:id="comboStatus" maxWidth="1.7976931348623157E308" promptText="Sélectionnez le statut" style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 5; -fx-text-fill: white;" />
            </VBox>

            <!-- Domaine -->
            <VBox spacing="8.0">
                <Label text="Domaine d'expertise :" textFill="#cbd5e1" style="-fx-font-weight: bold;" />
                <TextField fx:id="tfDomaine" promptText="Ex: Web, IA, Mobile..." style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12; -fx-text-fill: white;" />
            </VBox>

            <!-- Niveau -->
            <VBox spacing="8.0">
                <Label text="Niveau :" textFill="#cbd5e1" style="-fx-font-weight: bold;" />
                <TextField fx:id="tfNiveau" promptText="Ex: Débutant, Master..." style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12; -fx-text-fill: white;" />
            </VBox>

            <!-- Style d'apprentissage -->
            <VBox spacing="8.0">
                <Label text="Style d'apprentissage :" textFill="#cbd5e1" style="-fx-font-weight: bold;" />
                <TextField fx:id="tfStyle" promptText="Ex: Visuel, Auditif..." style="-fx-background-color: rgba(15, 23, 42, 0.5); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12; -fx-text-fill: white;" />
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- ACTIONS -->
    <HBox alignment="CENTER" spacing="15.0">
        <Button styleClass="btn-secondary" text="Annuler" fx:id="btnCancel" onAction="#handleCancel" prefWidth="120.0" />
        <Button styleClass="btn-primary" text="Sauvegarder" fx:id="btnSave" onAction="#handleSave" prefWidth="150.0" />
    </HBox>

</VBox>
