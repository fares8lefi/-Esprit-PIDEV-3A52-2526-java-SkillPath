<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<HBox xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="Controllers.user.admin.AjouterArchitecteController"
      prefHeight="800.0" prefWidth="1200.0" 
      style="-fx-background-color: #0f172a;"
      stylesheets="@../../../../FrontOffice/user/auth/style.css">
      
    <children>
        <!-- Sidebar -->
        <fx:include source="../SideBar.fxml" />

        <!-- Main Content (Scrollable) -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" HBox.hgrow="ALWAYS">
            <content>
                <VBox spacing="40.0" maxWidth="900.0">
                    <padding><Insets top="40" right="60" bottom="60" left="60"/></padding>
                    <children>
                        
                        <!-- Header with Breadcrumbs -->
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Button onAction="#handleBack" styleClass="btn-secondary" prefWidth="44" prefHeight="44">
                                    <graphic>
                                        <Label text="←" style="-fx-font-size: 18; -fx-text-fill: white;"/>
                                    </graphic>
                                </Button>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="GESTION DES UTILISATEURS" style="-fx-text-fill: #64748b; -fx-font-size: 10; -fx-font-weight: 900; -fx-letter-spacing: 2px;"/>
                                        <Label text="Créer un Utilisateur" textFill="WHITE">
                                            <font><Font name="System Bold" size="28.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- Form Card -->
                        <VBox spacing="35.0" styleClass="glass-card">
                            <padding><Insets top="45" right="45" bottom="45" left="45"/></padding>
                            <children>
                                <GridPane hgap="30.0" vgap="30.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    </columnConstraints>
                                    <rowConstraints>
                                        <RowConstraints vgrow="SOMETIMES" />
                                        <RowConstraints vgrow="SOMETIMES" />
                                        <RowConstraints vgrow="SOMETIMES" />
                                    </rowConstraints>
                                    
                                    <children>
                                        <!-- Nom d'Utilisateur -->
                                        <VBox spacing="8.0">
                                            <children>
                                                <Label text="NOM D'UTILISATEUR" styleClass="form-label"/>
                                                <TextField fx:id="usernameField" promptText="ex. john_doe" styleClass="form-input" />
                                            </children>
                                        </VBox>
                                        
                                        <!-- Email -->
                                        <VBox spacing="8.0" GridPane.columnIndex="1">
                                            <children>
                                                <Label text="EMAIL" styleClass="form-label"/>
                                                <TextField fx:id="emailField" promptText="ex. john@exemple.com" styleClass="form-input" />
                                            </children>
                                        </VBox>
                                        
                                        <!-- Mot de Passe -->
                                        <VBox spacing="8.0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                                            <children>
                                                <Label text="MOT DE PASSE" styleClass="form-label"/>
                                                <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="form-input" />
                                            </children>
                                        </VBox>
                                        
                                        <!-- Rôle -->
                                        <VBox spacing="8.0" GridPane.rowIndex="2">
                                            <children>
                                                <Label text="RÔLE" styleClass="form-label"/>
                                                <ComboBox fx:id="roleComboBox" maxWidth="Infinity" styleClass="form-input" />
                                            </children>
                                        </VBox>
                                        
                                        <!-- Statut (Display only as requested in template) -->
                                        <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                            <children>
                                                <Label text="STATUT" styleClass="form-label"/>
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 8 15; -fx-background-color: rgba(16, 185, 129, 0.1); -fx-background-radius: 12; -fx-border-color: rgba(16, 185, 129, 0.2); -fx-border-radius: 12; -fx-max-width: 100;">
                                                    <children>
                                                        <Circle radius="3" fill="#10b981" />
                                                        <Label text="ACTIF" style="-fx-text-fill: #10b981; -fx-font-size: 10; -fx-font-weight: 900;"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </GridPane>

                                <!-- Action Buttons -->
                                <Separator opacity="0.1" style="-fx-background-color: white;"/>
                                
                                <HBox spacing="20.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button fx:id="btnSubmit" onAction="#handleCreate" text="CRÉER L'UTILISATEUR" styleClass="btn-primary" prefHeight="50.0"/>
                                        <Button onAction="#handleBack" text="ANNULER" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-weight: bold; -fx-cursor: hand;"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</HBox>
