<AnchorPane styleClass="root" stylesheets="@../../FrontOffice/home/home_style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.event.UserFavouriteEventsController" prefWidth="1000" prefHeight="700">
    <children>
        <ScrollPane fitToWidth="true" styleClass="main-scroll-pane" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
