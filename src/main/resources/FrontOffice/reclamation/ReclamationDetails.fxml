<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="800.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.reclamation.ReclamationDetailsController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Button mnemonicParsing="false" onAction="#goBack" styleClass="btn-secondary" text="&lt; Retour" />
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblStatut" styleClass="status-pill-client" text="En attente" />
               </children>
            </HBox>

            <VBox styleClass="card" VBox.vgrow="NEVER">
               <children>
                  <Label text="Sujet" textFill="#64748b" />
                  <Label fx:id="lblSujet" styleClass="title-header" text="Titre de la reclamation" wrapText="true" />
                  <Label text="Description" textFill="#64748b">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Label>
                  <Label fx:id="lblDescription" text="Description detaillee de la reclamation..." wrapText="true" />
                  <Label text="Piece jointe" textFill="#64748b">
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </Label>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label fx:id="lblPieceJointe" text="Aucune piece jointe" />
                        <Button fx:id="btnOpenPieceJointe" managed="false" mnemonicParsing="false" onAction="#openPieceJointe" styleClass="btn-secondary" text="Ouvrir" visible="false" />
                     </children>
                  </HBox>
               </children>
            </VBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Discussion" textFill="#1e293b">
                     <font>
                        <javafx.scene.text.Font name="System Bold" size="16.0" />
                     </font>
                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>

                  <ScrollPane fx:id="chatScrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-border-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="chatContainer" spacing="15.0" style="-fx-padding: 10;" />
                     </content>
                  </ScrollPane>

                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <TextField fx:id="txtReponse" promptText="Ecrivez votre reponse ici..." styleClass="text-field-modern" HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#sendReponse" styleClass="btn-primary" text="Envoyer" />
                     </children>
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
