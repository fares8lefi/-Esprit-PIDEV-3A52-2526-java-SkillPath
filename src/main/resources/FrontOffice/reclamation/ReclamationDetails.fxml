<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.reclamation.ReclamationDetailsController">
   <children>
      <VBox spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-padding: 60 80 60 80;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#goBack" styleClass="btn-secondary" text="⬅ Retour" />
                  <Label styleClass="title-header" text="Détails de la Demande" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblStatut" styleClass="status-pill-client" text="En attente" />
               </children>
            </HBox>

            <HBox spacing="30.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Info Panel -->
                  <VBox spacing="25.0" styleClass="card" prefWidth="450.0">
                     <children>
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="label-form" text="Sujet" />
                              <Label fx:id="lblSujet" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" text="Titre de la réclamation" wrapText="true" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="label-form" text="Description" />
                              <Label fx:id="lblDescription" styleClass="subtitle" text="Description détaillée..." wrapText="true" />
                           </children>
                        </VBox>

                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="label-form" text="Pièce jointe" />
                              <HBox alignment="CENTER_LEFT" spacing="15.0">
                                 <children>
                                    <Label fx:id="lblPieceJointe" styleClass="subtitle" text="Aucune pièce jointe" />
                                    <Button fx:id="btnOpenPieceJointe" managed="false" mnemonicParsing="false" onAction="#openPieceJointe" styleClass="btn-secondary" style="-fx-padding: 8 15;" text="Ouvrir" visible="false" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- Chat Panel -->
                  <VBox spacing="20.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="label-form" text="Discussion avec le Support" />
      
                        <ScrollPane fx:id="chatScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                           <content>
                              <VBox fx:id="chatContainer" spacing="15.0" style="-fx-padding: 10;" />
                           </content>
                        </ScrollPane>
      
                        <HBox alignment="CENTER" spacing="15.0">
                           <children>
                              <TextField fx:id="txtReponse" promptText="Écrivez votre message..." styleClass="text-field-modern" HBox.hgrow="ALWAYS" />
                              <Button mnemonicParsing="false" onAction="#sendReponse" styleClass="btn-primary" text="Envoyer ✈" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
