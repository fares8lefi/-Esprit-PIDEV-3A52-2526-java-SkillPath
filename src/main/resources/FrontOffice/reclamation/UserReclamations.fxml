<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.user.reclamation.UserReclamationsController">
   <children>
      <VBox layoutX="30.0" layoutY="30.0" prefHeight="590.0" prefWidth="840.0" spacing="20.0" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0" AnchorPane.topAnchor="30.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox>
                     <children>
                        <Label styleClass="title-header" text="Mes Reclamations" />
                        <Label styleClass="subtitle" text="Gerez et suivez vos demandes d'assistance." />
                     </children>
                  </VBox>
                  <AnchorPane HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#goBackHome" styleClass="btn-secondary" text="&lt; Retour" />
                  <Button fx:id="btnAddReclamation" mnemonicParsing="false" onAction="#openAddReclamation" styleClass="btn-primary" text="+ Nouvelle Reclamation" />
               </children>
            </HBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="reclamationTable" prefHeight="450.0" prefWidth="800.0" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                      <TableColumn fx:id="colSujet" prefWidth="250.0" text="Sujet" />
                        <TableColumn fx:id="colStatut" prefWidth="150.0" text="Statut" />
                        <TableColumn fx:id="colAction" prefWidth="150.0" text="Action" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
