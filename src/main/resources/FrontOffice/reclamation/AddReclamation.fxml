<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.reclamation.AddReclamationController">
   <children>
      <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox maxWidth="600.0" prefWidth="600.0" spacing="25.0" styleClass="card">
               <children>
                  <VBox spacing="8.0">
                     <children>
                        <Label styleClass="title-header" text="Soumettre une Réclamation" />
                        <Label styleClass="subtitle" text="Notre équipe d'élite est à votre écoute pour résoudre tout incident." />
                     </children>
                  </VBox>
      
                  <VBox spacing="12.0">
                     <children>
                        <Label styleClass="label-form" text="Sujet" />
                        <TextField fx:id="txtSujet" promptText="Exemple: Bug technique sur un cours..." styleClass="text-field-modern" />
      
                        <Label styleClass="label-form" text="Description">
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </Label>
                        <TextArea fx:id="txtDescription" prefHeight="200.0" promptText="Détaillez votre problème ici..." styleClass="text-area-modern" wrapText="true" />
      
                        <Label styleClass="label-form" text="Pièce jointe (optionnel)">
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#chooseAttachment" styleClass="btn-secondary" text="📎 Parcourir" />
                              <Label fx:id="selectedFileLabel" styleClass="subtitle" text="Aucun fichier choisi" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
      
                  <HBox alignment="CENTER_RIGHT" spacing="20.0">
                     <children>
                        <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#cancel" styleClass="btn-secondary" text="Annuler" />
                        <Button fx:id="btnSubmit" mnemonicParsing="false" onAction="#submitReclamation" styleClass="btn-primary" text="🚀 Envoyer la demande" />
                     </children>
                     <VBox.margin>
                        <Insets top="15.0" />
                     </VBox.margin>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
               </padding>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
