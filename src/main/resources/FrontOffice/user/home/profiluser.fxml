<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #0f172a;" stylesheets="@../auth/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.user.ProfilUserController">
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <!-- Header (Navigation) -->
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.03); -fx-border-color: rgba(255, 255, 255, 0.05); -fx-border-width: 0 0 1 0;">
               <padding><Insets left="40.0" right="40.0" /></padding>
               <children>
                  <Button onAction="#handleBack" styleClass="btn-secondary" text="← Retour" />
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER" spacing="12.0">
                     <children>
                        <Label text="Mon" textFill="WHITE">
                           <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                        <Label text="Profil" textFill="#8b5cf6">
                           <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                     </children>
                  </HBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Region prefWidth="100.0" /> <!-- Spacer to balance the back button -->
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox alignment="TOP_CENTER" spacing="40.0" style="-fx-padding: 60 100 60 100;">
                     <children>
                        
                        <!-- Profile Header Card -->
                        <HBox alignment="CENTER_LEFT" spacing="40.0" styleClass="glass-card" style="-fx-padding: 40; -fx-background-radius: 30; -fx-border-radius: 30;">
                           <children>
                              <StackPane prefHeight="120.0" prefWidth="120.0" style="-fx-background-color: linear-gradient(to bottom right, #8b5cf6, #d946ef); -fx-background-radius: 30; -fx-effect: dropshadow(three-pass-box, rgba(139, 92, 246, 0.4), 20, 0, 0, 8);">
                                 <children>
                                    <Label fx:id="avatarInitial" text="J" textFill="WHITE">
                                       <font><Font name="System Bold" size="48.0" /></font>
                                    </Label>
                                 </children>
                              </StackPane>
                              <VBox spacing="10.0">
                                 <children>
                                    <Label fx:id="usernameTitle" text="John Doe" textFill="WHITE">
                                       <font><Font name="System Bold" size="36.0" /></font>
                                    </Label>
                                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                                       <children>
                                          <Label fx:id="roleLabel" text="ÉTUDIANT" textFill="#8b5cf6" style="-fx-background-color: rgba(139, 92, 246, 0.1); -fx-padding: 5 15; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 11;" />
                                          <Label text="● Compte Vérifié" textFill="#10b981" style="-fx-font-size: 11; -fx-font-weight: bold;" />
                                       </children>
                                    </HBox>
                                    <Label text="Gérez vos informations personnelles et préférences d'apprentissage." textFill="#94a3b8" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>

                        <!-- Information Form Grid -->
                        <GridPane hgap="30.0" vgap="40.0" styleClass="glass-card" style="-fx-padding: 50; -fx-background-radius: 30; -fx-border-radius: 30;">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           </columnConstraints>
                           
                           <children>
                              <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnSpan="2">
                                 <children>
                                    <Label text="Informations" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                                    <Label text="Générales" textFill="#8b5cf6" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                                 </children>
                                 <padding><Insets bottom="10" /></padding>
                              </HBox>
                              
                              <!-- Section 1: Personal Info -->
                              <VBox spacing="12.0" GridPane.rowIndex="1">
                                 <children>
                                    <Label styleClass="form-label" text="NOM D'UTILISATEUR" />
                                    <TextField fx:id="tfUsername" prefHeight="50.0" styleClass="form-input" />
                                 </children>
                              </VBox>
                              
                              <VBox spacing="12.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                 <children>
                                    <Label styleClass="form-label" text="ADRESSE EMAIL" />
                                    <TextField fx:id="tfEmail" editable="false" prefHeight="50.0" styleClass="form-input" style="-fx-opacity: 0.7;" />
                                 </children>
                              </VBox>

                              <!-- Section 2: Educational Info -->
                              <VBox spacing="12.0" GridPane.rowIndex="2">
                                 <children>
                                    <Label styleClass="form-label" text="DOMAINE D'EXPERTISE / INTÉRÊT" />
                                    <TextField fx:id="tfDomaine" prefHeight="50.0" styleClass="form-input" promptText="Ex: Développement Web, IA..." />
                                 </children>
                              </VBox>
                              
                              <VBox spacing="12.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                 <children>
                                    <Label styleClass="form-label" text="NIVEAU ACTUEL" />
                                    <TextField fx:id="tfNiveau" prefHeight="50.0" styleClass="form-input" promptText="Ex: Débutant, Intermédiaire, Expert" />
                                 </children>
                              </VBox>

                              <VBox spacing="12.0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                                 <children>
                                    <Label styleClass="form-label" text="STYLE D'APPRENTISSAGE PRÉFÉRÉ" />
                                    <TextField fx:id="tfStyle" prefHeight="50.0" styleClass="form-input" promptText="Ex: Visuel (vidéos), Pratique (projets), Théorique..." />
                                 </children>
                              </VBox>

                              <!-- Action Buttons -->
                              <HBox alignment="CENTER_RIGHT" spacing="20.0" GridPane.columnSpan="2" GridPane.rowIndex="4">
                                 <padding><Insets top="20.0" /></padding>
                                 <children>
                                    <Button onAction="#handleUpdate" prefHeight="50.0" prefWidth="220.0" styleClass="btn-primary" text="Sauvegarder mon profil" />
                                 </children>
                              </HBox>
                           </children>
                        </GridPane>

                        <!-- Password Change Section -->
                        <VBox spacing="30.0" styleClass="glass-card" style="-fx-padding: 50; -fx-background-radius: 30; -fx-border-radius: 30;">
                           <children>
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Sécurité &amp;" textFill="WHITE" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                                    <Label text="Mot de Passe" textFill="#f43f5e" style="-fx-font-size: 20; -fx-font-weight: bold;" />
                                 </children>
                              </HBox>
                              
                              <VBox spacing="25.0">
                                 <children>
                                    <VBox spacing="10.0">
                                       <children>
                                          <Label styleClass="form-label" text="MOT DE PASSE ACTUEL" />
                                          <PasswordField fx:id="tfCurrentPwd" prefHeight="50.0" styleClass="form-input" promptText="••••••••" />
                                       </children>
                                    </VBox>
                                    
                                    <HBox spacing="30.0">
                                       <children>
                                          <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                             <children>
                                                <Label styleClass="form-label" text="NOUVEAU MOT DE PASSE" />
                                                <PasswordField fx:id="tfNewPwd" prefHeight="50.0" styleClass="form-input" promptText="••••••••" />
                                             </children>
                                          </VBox>
                                          <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                             <children>
                                                <Label styleClass="form-label" text="CONFIRMER LE MOT DE PASSE" />
                                                <PasswordField fx:id="tfConfirmPwd" prefHeight="50.0" styleClass="form-input" promptText="••••••••" />
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>

                                    <HBox alignment="CENTER_RIGHT">
                                       <children>
                                          <Button onAction="#handleUpdatePassword" prefHeight="50.0" prefWidth="220.0" style="-fx-background-color: #f43f5e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="Changer le mot de passe" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>

                     </children>
                  </VBox>
               </content>
            </ScrollPane>

         </children>
      </VBox>
   </children>
</AnchorPane>
