<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.user.auth.ResetPasswordController" prefWidth="1000" prefHeight="700">
    <children>
        <HBox alignment="CENTER" spacing="60" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-padding: 50px;">
            
            <!-- Branding Side (Left) -->
            <VBox alignment="CENTER_LEFT" spacing="30" maxWidth="450" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 40 0;">
                    <StackPane styleClass="icon-box" style="-fx-background-color: linear-gradient(to bottom right, #8b5cf6, #d946ef); -fx-background-radius: 16px;" minWidth="56" minHeight="56">
                        <Label text="SP" style="-fx-font-weight: 900; -fx-text-fill: white; -fx-font-size: 22px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <HBox>
                            <Label text="Skill" styleClass="logo-text"/>
                            <Label text="Path" styleClass="logo-text" style="-fx-text-fill: #8b5cf6;"/>
                        </HBox>
                        <Label text="ELEVATE YOUR FUTURE" styleClass="logo-subtext"/>
                    </VBox>
                </HBox>

                <VBox spacing="0">
                    <Label text="Définir un" styleClass="title-text"/>
                    <Label text="nouveau mot de passe" styleClass="title-text" style="-fx-text-fill: #8b5cf6;"/>
                </VBox>
                
                <Label fx:id="emailLabel" text="Un code a été envoyé à votre adresse email." styleClass="subtitle-text" wrapText="true" maxWidth="380" style="-fx-padding: 0 0 20 0;"/>
            </VBox>

            <!-- Reset Password Card (Right) -->
            <VBox styleClass="glass-card" spacing="15" maxWidth="400" minWidth="380">
                <VBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Réinitialisation" styleClass="card-title"/>
                    <Label text="Entrez le code et votre nouveau mot de passe." styleClass="card-subtitle"/>
                </VBox>

                <VBox fx:id="alertBox" visible="false" managed="false" spacing="10" styleClass="alert-box">
                    <Label fx:id="alertLabel" wrapText="true" />
                </VBox>

                <VBox spacing="6">
                    <Label text="CODE DE VÉRIFICATION" styleClass="form-label"/>
                    <TextField fx:id="codeField" promptText="123456" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="NOUVEAU MOT DE PASSE" styleClass="form-label"/>
                    <PasswordField fx:id="newPasswordField" promptText="8 caractères minimum" styleClass="form-input"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="CONFIRMER LE MOT DE PASSE" styleClass="form-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Répétez le mot de passe" styleClass="form-input"/>
                </VBox>

                <Button fx:id="resetBtn" onAction="#handleResetPassword" text="Réinitialiser le mot de passe" styleClass="btn-primary" maxWidth="Infinity">
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                </Button>

                <VBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                    <Hyperlink onAction="#handleBackToLogin" text="Retour à la connexion" styleClass="link"/>
                </VBox>
            </VBox>

        </HBox>
    </children>
</AnchorPane>
