<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane styleClass="root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.user.auth.ForgotPasswordController" prefWidth="1000" prefHeight="700">
    <children>
        <HBox alignment="CENTER" spacing="60" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-padding: 50px;">
            
            <!-- Branding Side (Left) -->
            <VBox alignment="CENTER_LEFT" spacing="30" maxWidth="450" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 0 0 40 0;">
                    <StackPane styleClass="icon-box" style="-fx-background-color: linear-gradient(to bottom right, #8b5cf6, #d946ef); -fx-background-radius: 16px;" minWidth="56" minHeight="56">
                        <Label text="SP" style="-fx-font-weight: 900; -fx-text-fill: white; -fx-font-size: 22px;"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <HBox>
                            <Label text="Skill" styleClass="logo-text"/>
                            <Label text="Path" styleClass="logo-text" style="-fx-text-fill: #8b5cf6;"/>
                        </HBox>
                        <Label text="ELEVATE YOUR FUTURE" styleClass="logo-subtext"/>
                    </VBox>
                </HBox>

                <VBox spacing="0">
                    <Label text="Récupération de" styleClass="title-text"/>
                    <Label text="compte" styleClass="title-text" style="-fx-text-fill: #8b5cf6;"/>
                </VBox>
                
                <Label text="Entrez votre adresse e-mail pour recevoir un code de réinitialisation de mot de passe." styleClass="subtitle-text" wrapText="true" maxWidth="380" style="-fx-padding: 0 0 20 0;"/>
            </VBox>

            <!-- Forgot Password Card (Right) -->
            <VBox styleClass="glass-card" spacing="25" maxWidth="400" minWidth="380">
                <VBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Mot de passe oublié" styleClass="card-title"/>
                    <Label text="Nous allons vous aider à revenir." styleClass="card-subtitle"/>
                </VBox>

                <VBox fx:id="alertBox" visible="false" managed="false" spacing="10" styleClass="alert-box">
                    <Label fx:id="alertLabel" wrapText="true" />
                </VBox>

                <VBox spacing="8">
                    <Label text="VOTRE EMAIL" styleClass="form-label"/>
                    <TextField fx:id="emailField" promptText="nom@exemple.com" styleClass="form-input"/>
                </VBox>

                <Button fx:id="sendBtn" onAction="#handleSendCode" text="Envoyer le code" styleClass="btn-primary" maxWidth="Infinity">
                    <VBox.margin>
                        <Insets top="10"/>
                    </VBox.margin>
                </Button>

                <VBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                    <Hyperlink onAction="#handleBackToLogin" text="Retour à la connexion" styleClass="link"/>
                </VBox>
            </VBox>

        </HBox>
    </children>
</AnchorPane>
