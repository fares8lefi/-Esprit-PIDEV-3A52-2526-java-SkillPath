<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="Controllers.course.FrontCourseCardController"
      styleClass="glass-card-elite" 
      spacing="0" prefHeight="260.0" minWidth="800"
      style="-fx-padding: 0; -fx-overflow: hidden;"
      onMouseEntered="#handleHoverIn" onMouseExited="#handleHoverOut">
    
    <children>
        <!-- Card Image Section -->
        <StackPane fx:id="imageContainer" minWidth="300" maxWidth="300" style="-fx-background-color: #0f172a;">
            <children>
                <ImageView fx:id="imgCourse" fitWidth="300" fitHeight="260" pickOnBounds="true" preserveRatio="false" />
                
                <!-- Price Badge Overlay -->
                <Label fx:id="lblPrice" text="Gratuit" StackPane.alignment="TOP_LEFT"
                       style="-fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-padding: 8 16; -fx-background-radius: 12; -fx-font-weight: 900; -fx-font-size: 11; -fx-letter-spacing: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                    <StackPane.margin><Insets top="20" left="20"/></StackPane.margin>
                </Label>
            </children>
        </StackPane>

        <!-- Card Content Section -->
        <VBox HBox.hgrow="ALWAYS" spacing="15">
            <padding><Insets top="30" bottom="30" left="35" right="35"/></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <children>
                        <Label fx:id="lblCategory" text="DÉVELOPPEMENT" 
                               styleClass="category-badge-base, cat-default" />
                        <HBox spacing="5" alignment="CENTER">
                            <children>
                                <Label text="★" style="-fx-font-size: 14; -fx-text-fill: #fbbf24;" />
                                <Label text="4.8" style="-fx-text-fill: #fbbf24; -fx-font-weight: 900; -fx-font-size: 12;" />
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnFavorite" onAction="#handleFavoriteToggle"
                                style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-padding: 0; -fx-cursor: hand; -fx-font-size: 22;" 
                                text="♡" />
                    </children>
                </HBox>

                <VBox spacing="10">
                    <children>
                        <Label fx:id="lblTitle" text="Formation Java Expert" wrapText="true"
                               style="-fx-text-fill: white; -fx-font-size: 26; -fx-font-weight: 900; -fx-letter-spacing: -0.5;" />
                        <Label fx:id="lblDescription" text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor..." 
                               wrapText="true" prefHeight="45"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14; -fx-line-spacing: 5;" />
                    </children>
                </VBox>

                <HBox spacing="25" alignment="CENTER_LEFT">
                    <children>
                        <!-- Level Badge -->
                        <HBox spacing="8" alignment="CENTER">
                            <children>
                                <Label text="⚡" style="-fx-font-size: 14; -fx-text-fill: #8b5cf6;" />
                                <Label fx:id="lblLevel" text="Intermédiaire" style="-fx-text-fill: #cbd5e1; -fx-font-weight: bold; -fx-font-size: 12;" />
                            </children>
                        </HBox>
                        
                        <!-- AI Probability Badge -->
                        <HBox fx:id="aiBadge" spacing="10" alignment="CENTER" styleClass="ai-pulse"
                               style="-fx-background-color: rgba(59,130,246,0.1); -fx-padding: 8 16; -fx-background-radius: 12; -fx-border-color: rgba(59,130,246,0.2); -fx-border-radius: 12;">
                            <children>
                                <Label text="🪄" style="-fx-font-size: 14;" />
                                <Label fx:id="lblAiProb" text="85% Succès" 
                                       style="-fx-text-fill: #60a5fa; -fx-font-weight: 900; -fx-font-size: 10; -fx-letter-spacing: 1;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Bottom Part -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <children>
                        <HBox alignment="CENTER" spacing="12">
                            <children>
                                <StackPane prefHeight="36" prefWidth="36" style="-fx-background-color: linear-gradient(to bottom right, #8b5cf6, #d946ef); -fx-background-radius: 18;">
                                    <children><Label text="SP" textFill="WHITE" style="-fx-font-size: 11; -fx-font-weight: 900;" /></children>
                                </StackPane>
                                <VBox>
                                    <children>
                                        <Label text="SkillPath Team" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 12;" />
                                        <Label text="INSTRUCTORS" textFill="#64748b" style="-fx-font-size: 9; -fx-font-weight: 900; -fx-letter-spacing: 1;" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="Consulter" prefHeight="45" prefWidth="130" onAction="#handleViewDetails"
                                style="-fx-background-color: #ffffff; -fx-text-fill: #0f172a; -fx-font-weight: 900; -fx-font-size: 13; -fx-background-radius: 14; -fx-cursor: hand;" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</HBox>
