<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #05070A;" stylesheets="@../user/auth/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.course.RecommendationController">
   <children>
      <!-- Background Glow -->
      <Circle fill="#1e293b" radius="300.0" layoutX="1100.0" layoutY="100.0" opacity="0.1" />
      <Circle fill="#8b5cf6" radius="200.0" layoutX="100.0" layoutY="700.0" opacity="0.05" />

      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Navigation Bar -->
            <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="30.0" style="-fx-background-color: rgba(11, 15, 26, 0.8); -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0; -fx-padding: 0 50;">
               <children>
                  <Label text="SkillPath" textFill="WHITE" style="-fx-font-size: 24; -fx-font-weight: 900; -fx-letter-spacing: -1;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER" spacing="25.0">
                     <children>
                        <Button onAction="#goToHome" text="ACCUEIL" styleClass="nav-item" />
                        <Button onAction="#goToCourseList" text="COURS" styleClass="nav-item" />
                        <Button text="RECOMMANDATIONS" styleClass="nav-item-active" />
                     </children>
                  </HBox>
               </children>
            </HBox>

            <HBox spacing="40.0" VBox.vgrow="ALWAYS" style="-fx-padding: 40 50;">
               <children>
                  <!-- Left Panel: AI Insights -->
                  <VBox prefWidth="300.0" spacing="25.0">
                     <children>
                        <VBox styleClass="glass-card-elite" spacing="20.0" style="-fx-padding: 25;">
                           <children>
                              <HBox spacing="10.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="🪄" style="-fx-font-size: 20;" />
                                    <Label text="IA INSIGHTS" textFill="#8b5cf6" style="-fx-font-size: 11; -fx-font-weight: 900; -fx-letter-spacing: 1.5;" />
                                 </children>
                              </HBox>
                              <VBox spacing="8.0">
                                 <children>
                                    <Label text="Profil détecté :" textFill="#94a3b8" style="-fx-font-size: 12;" />
                                    <Label fx:id="lblDetectedProfile" text="Développement (Débutant)" textFill="WHITE" wrapText="true" style="-fx-font-size: 18; -fx-font-weight: bold;" />
                                 </children>
                              </VBox>
                              <Separator opacity="0.1" />
                              <Label text="Nous analysons vos clics en temps réel pour affiner ces suggestions." textFill="#64748b" wrapText="true" style="-fx-font-size: 11; -fx-font-style: italic;" />
                           </children>
                        </VBox>

                        <VBox styleClass="glass-card-elite" spacing="20.0" style="-fx-padding: 25;">
                           <children>
                              <Label text="VOTRE BUDGET" textFill="#8b5cf6" style="-fx-font-size: 11; -fx-font-weight: 900; -fx-letter-spacing: 1.5;" />
                              <VBox spacing="15.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Max :" textFill="#94a3b8" style="-fx-font-size: 12;" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label fx:id="lblBudget" text="1000 DT" textFill="WHITE" style="-fx-font-weight: 900;" />
                                       </children>
                                    </HBox>
                                    <Slider fx:id="budgetSlider" max="1000.0" value="1000.0" style="-fx-accent: #8b5cf6;" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>

                  <!-- Right Panel: Course List -->
                  <VBox HBox.hgrow="ALWAYS" spacing="25.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Sélectionné pour vous" textFill="WHITE" style="-fx-font-size: 32; -fx-font-weight: 900;" />
                              <Label text="Basé sur vos centres d'intérêt récents et votre budget." textFill="#94a3b8" style="-fx-font-size: 14;" />
                           </children>
                        </VBox>

                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                           <content>
                              <VBox fx:id="recommendationsContainer" spacing="20.0" style="-fx-padding: 10 0;">
                                 <!-- Course Cards will be loaded here -->
                              </VBox>
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
