<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<VBox id="itemWrapper" alignment="CENTER_LEFT" prefHeight="70.0" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-background-radius: 16; -fx-border-color: transparent; -fx-border-width: 1; -fx-cursor: hand;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <padding><Insets left="15.0" right="15.0" /></padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <StackPane id="indexBox" prefHeight="32.0" prefWidth="32.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 8;">
               <children>
                  <Label id="indexLabel" text="1" textFill="#94a3b8" style="-fx-font-size: 11; -fx-font-weight: bold;" />
               </children>
            </StackPane>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label id="titleLabel" text="Titre du Module" textFill="#cbd5e1" style="-fx-font-size: 13; -fx-font-weight: bold;" />
                  <Label id="typeLabel" text="VIDEO" textFill="#64748b" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-letter-spacing: 1;" />
               </children>
            </VBox>
            <Label id="lockIcon" text="🔒" visible="false" managed="false" style="-fx-font-size: 14;" />
         </children>
      </HBox>
   </children>
</VBox>
