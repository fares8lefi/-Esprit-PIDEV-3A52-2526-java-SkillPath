<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="Controllers.course.FrontCourseDetailsController"
            prefHeight="900.0" prefWidth="1440.0"
            style="-fx-background-color: #0b1120;"
            stylesheets="@../user/auth/style.css">

    <children>
        <!-- Layer 1: Main Application Structure -->
        <BorderPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
            
            <!-- Navbar Area (Synced with List) -->
            <top>
                <HBox alignment="CENTER" prefHeight="90.0" style="-fx-background-color: #0f172a; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
                    <padding><Insets left="80" right="80"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15" HBox.hgrow="ALWAYS" onMouseClicked="#handleBackClick" style="-fx-cursor: hand;">
                            <children>
                                <StackPane prefHeight="48" prefWidth="48" style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #a855f7); -fx-background-radius: 14;">
                                    <children><Label text="S" textFill="WHITE" style="-fx-font-size: 24; -fx-font-weight: 900;" /></children>
                                </StackPane>
                                <Label text="SkillPath" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;" />
                            </children>
                        </HBox>
                        
                        <HBox alignment="CENTER" spacing="50">
                            <children>
                                <Hyperlink text="ACCUEIL" onAction="#goToHome" style="-fx-text-fill: #94a3b8; -fx-font-weight: 900; -fx-font-size: 11; -fx-letter-spacing: 2.5;" />
                                <Hyperlink text="MES COURS" onAction="#handleBack" style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 11; -fx-letter-spacing: 2.5;" />
                                <Hyperlink text="ÉVÉNEMENTS" style="-fx-text-fill: #94a3b8; -fx-font-weight: 900; -fx-font-size: 11; -fx-letter-spacing: 2.5;" />
                                <Hyperlink text="RECOMMANDATIONS" style="-fx-text-fill: #94a3b8; -fx-font-weight: 900; -fx-font-size: 11; -fx-letter-spacing: 2.5;" />
                            </children>
                        </HBox>

                        <HBox alignment="CENTER_RIGHT" spacing="25" HBox.hgrow="ALWAYS">
                            <children>
                                <!-- Premium Notification Icon -->
                                <StackPane style="-fx-cursor: hand; -fx-padding: 5;">
                                    <children>
                                        <Label text="🔔" style="-fx-font-size: 24; -fx-text-fill: #94a3b8;" />
                                        <StackPane StackPane.alignment="TOP_RIGHT" maxHeight="18" maxWidth="18" minHeight="18" minWidth="18"
                                                   style="-fx-background-color: #ef4444; -fx-background-radius: 10; -fx-border-color: #0f172a; -fx-border-width: 2; -fx-border-radius: 10;">
                                            <children><Label text="2" textFill="WHITE" style="-fx-font-size: 9; -fx-font-weight: 900;" /></children>
                                            <StackPane.margin><Insets top="-2" right="-2"/></StackPane.margin>
                                        </StackPane>
                                    </children>
                                </StackPane>
                                
                                <Separator orientation="VERTICAL" maxHeight="30" opacity="0.1" />
                                <Button text="DÉCONNEXION" style="-fx-background-color: transparent; -fx-text-fill: #f43f5e; -fx-font-weight: bold; -fx-font-size: 11; -fx-letter-spacing: 2;" />
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </top>

            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;">
                    <content>
                        <VBox>
                            <children>
                                <!-- Detailed Hero Section -->
                                <StackPane prefHeight="450.0" style="-fx-background-color: #111827; -fx-border-color: rgba(255,255,255,0.04); -fx-border-width: 0 0 1 0;">
                                    <children>
                                        <VBox alignment="CENTER_LEFT" spacing="30">
                                            <padding><Insets left="150" right="150"/></padding>
                                            <children>
                                                <HBox spacing="15" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label fx:id="lblCategory" text="DÉVELOPPEMENT" style="-fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-font-size: 13; -fx-letter-spacing: 2.5; -fx-background-color: rgba(99,102,241,0.1); -fx-padding: 8 20; -fx-background-radius: 20;" />
                                                        <Label text="•" textFill="#4b5563" />
                                                        <Label fx:id="lblLevel" text="Intermédiaire" textFill="#94a3b8" style="-fx-font-weight: 800; -fx-font-size: 16;" />
                                                    </children>
                                                </HBox>
                                                <Label fx:id="lblTitle" text="Titre de la formation" wrapText="true" maxWidth="900"
                                                       style="-fx-font-size: 64; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: -2; -fx-line-spacing: -10;" />
                                                <HBox spacing="40" alignment="CENTER_LEFT">
                                                    <children>
                                                        <HBox spacing="12" alignment="CENTER">
                                                            <children>
                                                                <Label text="⭐" style="-fx-font-size: 20;" />
                                                                <Label text="4.8 (128 avis)" textFill="#fbbf24" style="-fx-font-weight: 900; -fx-font-size: 18;" />
                                                            </children>
                                                        </HBox>
                                                        <HBox spacing="12" alignment="CENTER">
                                                            <children>
                                                                <Label text="👥" style="-fx-font-size: 20;" />
                                                                <Label text="2,450 inscrits" textFill="#94a3b8" style="-fx-font-weight: 900; -fx-font-size: 18;" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>

                                <!-- Main Info Section -->
                                <HBox spacing="80">
                                    <padding><Insets left="150" right="150" top="80" bottom="150"/></padding>
                                    <children>
                                        <!-- Left Column -->
                                        <VBox spacing="60" HBox.hgrow="ALWAYS">
                                            <children>
                                                <VBox spacing="25">
                                                    <children>
                                                        <Label text="À propos de ce cours" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: -1;" />
                                                        <Label fx:id="lblDescription" text="Description..." wrapText="true" 
                                                               style="-fx-font-size: 18; -fx-text-fill: #94a3b8; -fx-line-spacing: 8;" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="35">
                                                    <children>
                                                        <Label text="Programme de la formation" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: -1;" />
                                                        <VBox fx:id="modulesContainer" spacing="20" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <!-- Rigth Column (Sidebar Sticky-like) -->
                                        <VBox spacing="40" minWidth="450">
                                            <children>
                                                <VBox styleClass="glass-card-elite" spacing="35" style="-fx-padding: 45;">
                                                    <children>
                                                        <StackPane prefHeight="260" style="-fx-background-color: #0f172a; -fx-background-radius: 20; -fx-overflow: hidden; -fx-border-color: rgba(255,255,255,0.06); -fx-border-radius: 20;">
                                                            <children>
                                                                <ImageView fx:id="imgCourse" fitWidth="360" fitHeight="260" pickOnBounds="true" preserveRatio="false" />
                                                                <Button style="-fx-background-color: rgba(255,107,15,0.1); -fx-background-radius: 50; -fx-min-width: 80; -fx-min-height: 80; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 50; -fx-border-width: 2;">
                                                                    <graphic><Label text="▶" textFill="WHITE" style="-fx-font-size: 32;" /></graphic>
                                                                </Button>
                                                            </children>
                                                        </StackPane>

                                                        <VBox spacing="15">
                                                            <children>
                                                                <Label fx:id="lblPrice" text="49.99 DT" style="-fx-font-size: 48; -fx-font-weight: bold; -fx-text-fill: white;" />
                                                                <HBox spacing="10" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="✨" />
                                                                        <Label text="Accès illimité à la SkillBox incluse" textFill="#4ade80" style="-fx-font-weight: 900; -fx-font-size: 14;" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>

                                                        <Button text="REJOINDRE LA FORMATION" maxWidth="Infinity" prefHeight="70"
                                                                style="-fx-background-color: linear-gradient(to right, #6366f1, #9333ea); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15; -fx-background-radius: 18; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.5), 30, 0, 0, 15);" />
                                                        
                                                        <VBox spacing="20">
                                                            <children>
                                                                <Label text="CE COURS COMPREND" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-letter-spacing: 2.5;" />
                                                                <HBox spacing="15" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="🎥" style="-fx-font-size: 18;" />
                                                                        <Label fx:id="lblModuleInfo" text="12 modules exclusifs" textFill="WHITE" style="-fx-font-size: 14; -fx-font-weight: 700;" />
                                                                    </children>
                                                                </HBox>
                                                                <HBox spacing="15" alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="🎖️" style="-fx-font-size: 18;" />
                                                                        <Label text="Certification SkillPath officielle" textFill="WHITE" style="-fx-font-size: 14; -fx-font-weight: 700;" />
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>

                                                <VBox styleClass="glass-card-elite" spacing="22" style="-fx-background-color: linear-gradient(to bottom right, rgba(99,102,241,0.15), rgba(0,0,0,0)); -fx-padding: 40; -fx-border-color: rgba(99,102,241,0.3);">
                                                    <children>
                                                        <HBox spacing="12" alignment="CENTER_LEFT">
                                                            <children>
                                                                <Label text="🪄" style="-fx-font-size: 24;" />
                                                                <Label text="Prédiction de Succès IA" textFill="#818cf8" style="-fx-font-weight: bold; -fx-font-size: 16;" />
                                                            </children>
                                                        </HBox>
                                                        <Label text="Notre algorithme estime que vous maîtriserez 92% du contenu en 3 semaines selon vos acquis." 
                                                               textFill="#94a3b8" wrapText="true" style="-fx-font-size: 13; -fx-line-spacing: 5;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>

        <!-- Layer 2: Floating Overlays (Absolute Positioning) -->
        <VBox fx:id="chatContainer" AnchorPane.bottomAnchor="40" AnchorPane.rightAnchor="40" spacing="20" alignment="BOTTOM_RIGHT" pickOnBounds="false">
            <children>
                <VBox fx:id="chatWindow" visible="false" prefHeight="600" prefWidth="420" 
                      style="-fx-background-color: #0f172a; -fx-background-radius: 32; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 60, 0, 0, 30); -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 32;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="18" prefHeight="100" style="-fx-background-color: linear-gradient(to right, #4f46e5, #9333ea); -fx-background-radius: 32 32 0 0;">
                            <padding><Insets left="35" right="35"/></padding>
                            <children>
                                <Circle radius="24" fill="white" opacity="0.15" />
                                <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Service Clientèle IA" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 17;" />
                                        <Label text="En ligne • Réponses instantanées" textFill="rgba(255,255,255,0.7)" style="-fx-font-size: 11; -fx-font-weight: 800;" />
                                    </children>
                                </VBox>
                                <Button onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 28; -fx-cursor: hand;" text="×" />
                            </children>
                        </HBox>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                            <content><VBox fx:id="chatMessages" spacing="28" style="-fx-padding: 35; -fx-background-color: #0f172a;" /></content>
                        </ScrollPane>
                        <VBox style="-fx-background-color: #1a2234; -fx-padding: 30; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 1 0 0 0;">
                            <children>
                                <HBox spacing="15" alignment="CENTER">
                                    <children>
                                        <TextField fx:id="txtChatInput" promptText="Posez vos questions sur ce cours..." HBox.hgrow="ALWAYS" onAction="#sendChatMessage"
                                                   styleClass="premium-search" style="-fx-background-radius: 30; -fx-padding: 16 30;" />
                                        <Button onAction="#sendChatMessage" prefHeight="60" prefWidth="60" 
                                                style="-fx-background-color: #6366f1; -fx-background-radius: 30; -fx-cursor: hand;">
                                            <graphic><Label text="➜" textFill="WHITE" style="-fx-font-size: 20;" /></graphic>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
                <Button onAction="#toggleChat" prefHeight="85" prefWidth="85" 
                        style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #9333ea); -fx-background-radius: 45; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.6), 40, 0, 0, 20); -fx-cursor: hand;">
                    <graphic><Label text="💬" textFill="WHITE" style="-fx-font-size: 38;" /></graphic>
                </Button>
            </children>
        </VBox>
    </children>
</AnchorPane>
