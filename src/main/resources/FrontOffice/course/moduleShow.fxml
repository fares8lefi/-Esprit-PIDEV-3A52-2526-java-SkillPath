<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.web.*?>

<AnchorPane prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #0f172a;" stylesheets="@../user/auth/style.css, @module_show_style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.course.FrontModuleShowController">
   <children>
      <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            
            <!-- 1. Sidebar Navigation -->
            <VBox minWidth="320.0" prefWidth="320.0" style="-fx-background-color: #0B0F1A; -fx-border-color: rgba(255, 255, 255, 0.05); -fx-border-width: 0 1 0 0;">
               <children>
                  <VBox spacing="20.0" style="-fx-padding: 30; -fx-background-color: rgba(0,0,0,0.2);">
                     <children>
                        <!-- Back to Home -->
                        <HBox alignment="CENTER_LEFT" onMouseClicked="#goToHome" spacing="15.0" style="-fx-cursor: hand;">
                           <children>
                              <StackPane prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 12;">
                                 <children><Label text="🏠" textFill="#94a3b8" /></children>
                              </StackPane>
                              <VBox>
                                 <children>
                                    <Label text="ACCUEIL" textFill="#94a3b8" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-letter-spacing: 1.5;" />
                                    <Label text="Retour au site" textFill="#64748b" style="-fx-font-size: 9;" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <VBox spacing="5.0">
                           <children>
                              <Label fx:id="courseTitleSidebar" text="TITRE DU COURS" textFill="#94a3b8" wrapText="true" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-letter-spacing: 1;" />
                              <ProgressBar fx:id="courseProgressBar" prefHeight="6.0" prefWidth="Infinity" progress="0.4" style="-fx-accent: #8b5cf6;" />
                              <Label fx:id="progressPercent" text="40% Complété" textFill="#64748b" style="-fx-font-size: 10; -fx-font-weight: bold;" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="modulesContainer" spacing="10.0" style="-fx-padding: 20;">
                           <!-- Modules will be loaded here -->
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>

            <!-- 2. Main Content -->
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <!-- Header -->
                  <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="15.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                     <padding><Insets left="40.0" right="40.0" /></padding>
                     <children>
                        <Label fx:id="breadcrumbCourse" text="Cours" textFill="#94a3b8" style="-fx-font-weight: bold;" />
                        <Label text="•" textFill="#1e293b" />
                        <Label fx:id="breadcrumbModule" text="Module Actuel" textFill="WHITE" style="-fx-font-weight: bold;" />
                     </children>
                  </HBox>
                  
                  <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox spacing="40.0" style="-fx-padding: 50 100 50 100;">
                           <children>
                              
                              <!-- Video Placeholder -->
                              <VBox fx:id="videoContainer" alignment="CENTER" prefHeight="450.0" style="-fx-background-color: black; -fx-background-radius: 30; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 30; -fx-overflow: hidden;">
                                 <children>
                                    <StackPane style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 50; -fx-padding: 20; -fx-cursor: hand;">
                                       <children><Label text="▶" textFill="WHITE" style="-fx-font-size: 40;" /></children>
                                    </StackPane>
                                 </children>
                              </VBox>
                              
                              <!-- Module Header -->
                              <HBox spacing="30.0" alignment="CENTER_LEFT">
                                 <children>
                                    <StackPane prefHeight="120.0" prefWidth="120.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 24; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 24;">
                                       <children>
                                          <ImageView fx:id="moduleImageView" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true" />
                                       </children>
                                    </StackPane>
                                    <VBox spacing="10.0">
                                       <children>
                                          <Label fx:id="moduleTypeBadge" text="VIDEO" textFill="WHITE" style="-fx-background-color: #8b5cf6; -fx-background-radius: 8; -fx-padding: 4 12; -fx-font-size: 10; -fx-font-weight: bold;" />
                                          <Label fx:id="moduleTitle" text="Titre du Module" textFill="WHITE" style="-fx-font-size: 48; -fx-font-weight: 900; -fx-letter-spacing: -1;" />
                                          <Label fx:id="moduleMeta" text="Niveau • Date d'ajout" textFill="#94a3b8" style="-fx-font-size: 14;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              
                              <!-- Description & Content -->
                              <VBox spacing="25.0">
                                 <children>
                                    <Label fx:id="moduleDescription" text="Description..." textFill="#cbd5e1" wrapText="true" style="-fx-font-size: 18; -fx-font-style: italic; -fx-border-color: #8b5cf6; -fx-border-width: 0 0 0 4; -fx-padding: 0 0 0 20;" />
                                    <Label fx:id="moduleContent" text="Contenu textuel du module ici..." textFill="#94a3b8" wrapText="true" style="-fx-font-size: 16; -fx-line-spacing: 5;" />
                                 </children>
                              </VBox>
                              
                              <!-- Document Reader Shell -->
                              <VBox fx:id="docReaderSection" spacing="20.0" style="-fx-padding: 40 0 0 0;">
                                 <children>
                                    <HBox alignment="CENTER" spacing="15.0">
                                       <children>
                                          <Separator HBox.hgrow="ALWAYS" opacity="0.1" />
                                          <Label text="RESSOURCE DU MODULE" textFill="#8b5cf6" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-letter-spacing: 2;" />
                                          <Separator HBox.hgrow="ALWAYS" opacity="0.1" />
                                       </children>
                                    </HBox>
                                    
                                    <VBox style="-fx-background-color: #0d111c; -fx-background-radius: 24; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 24; -fx-overflow: hidden;">
                                       <children>
                                          <!-- Reader Toolbar -->
                                          <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: rgba(255,255,255,0.03); -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                                             <padding><Insets left="20.0" right="20.0" /></padding>
                                             <children>
                                                <HBox spacing="8.0">
                                                   <children>
                                                      <Circle fill="#f87171" radius="6.0" />
                                                      <Circle fill="#fbbf24" radius="6.0" />
                                                      <Circle fill="#34d399" radius="6.0" />
                                                   </children>
                                                </HBox>
                                                <Separator orientation="VERTICAL" maxHeight="20.0" opacity="0.1" />
                                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 10; -fx-padding: 5 12;">
                                                   <children>
                                                      <Label text="📄" textFill="#94a3b8" />
                                                      <Label fx:id="fileNameLabel" text="document.pdf" textFill="#cbd5e1" style="-fx-font-size: 11; -fx-font-weight: bold;" />
                                                      <Label fx:id="fileExtLabel" text="PDF" textFill="#f87171" style="-fx-font-size: 9; -fx-font-weight: 900; -fx-background-color: rgba(248,113,113,0.1); -fx-padding: 2 6; -fx-background-radius: 4;" />
                                                   </children>
                                                </HBox>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button text="⬇" style="-fx-background-color: transparent;" textFill="#94a3b8" />
                                             </children>
                                          </HBox>
                                          
                                          <!-- Document placeholder replaced with Button to avoid dependency -->
                                          <VBox alignment="CENTER" prefHeight="200.0" spacing="15.0" style="-fx-padding: 40;">
                                             <children>
                                                <Label text="📄" style="-fx-font-size: 40;" />
                                                <Label text="Le document est prêt pour la consultation." textFill="#94a3b8" />
                                                <Button onAction="#handleOpenDocument" styleClass="btn-primary" text="Ouvrir le document" />
                                             </children>
                                          </VBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>
                              
                              <!-- Footer Navigation -->
                              <HBox alignment="CENTER" prefHeight="100.0" style="-fx-padding: 50 0 0 0; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 1 0 0 0;">
                                 <children>
                                    <!-- Prev -->
                                    <VBox fx:id="prevModuleBtn" spacing="5.0" style="-fx-cursor: hand;">
                                       <children>
                                          <Label text="PRÉCÉDENT" textFill="#64748b" style="-fx-font-size: 10; -fx-font-weight: bold;" />
                                          <HBox alignment="CENTER_LEFT" spacing="15.0">
                                             <children>
                                                <StackPane prefHeight="48.0" prefWidth="48.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 12;">
                                                   <children><Label text="←" textFill="WHITE" /></children>
                                                </StackPane>
                                                <Label fx:id="prevModuleTitle" text="Module Précédent" textFill="WHITE" style="-fx-font-weight: bold;" />
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    
                                    <Region HBox.hgrow="ALWAYS" />
                                    
                                    <!-- Next or Finish -->
                                    <StackPane>
                                       <children>
                                          <VBox fx:id="nextModuleBtn" alignment="CENTER_RIGHT" spacing="5.0" style="-fx-cursor: hand;">
                                             <children>
                                                <Label text="SUIVANT" textFill="#64748b" style="-fx-font-size: 10; -fx-font-weight: bold;" />
                                                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                                   <children>
                                                      <Label fx:id="nextModuleTitle" text="Module Suivant" textFill="WHITE" style="-fx-font-weight: bold;" />
                                                      <StackPane prefHeight="48.0" prefWidth="48.0" style="-fx-background-color: rgba(255,255,255,0.02); -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 12;">
                                                         <children><Label text="→" textFill="WHITE" /></children>
                                                      </StackPane>
                                                   </children>
                                                </HBox>
                                             </children>
                                          </VBox>
                                          <Button fx:id="finishCourseBtn" onAction="#handleFinishCourse" styleClass="btn-primary" text="Terminer le cours ✓" visible="false" />
                                       </children>
                                    </StackPane>
                                 </children>
                              </HBox>
                              
                           </children>
                        </VBox>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
         </children>
      </HBox>
    </children>

    <!-- Layer 2: Floating Overlays (Absolute Positioning) -->
    <VBox fx:id="chatContainer" AnchorPane.bottomAnchor="40" AnchorPane.rightAnchor="40" spacing="20" alignment="BOTTOM_RIGHT" pickOnBounds="false">
        <children>
            <!-- Chat Window -->
            <VBox fx:id="chatWindow" visible="false" prefHeight="600" prefWidth="420" 
                  style="-fx-background-color: #0f172a; -fx-background-radius: 32; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.7), 60, 0, 0, 30); -fx-border-color: rgba(255,255,255,0.12); -fx-border-radius: 32;">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="18" prefHeight="100" style="-fx-background-color: linear-gradient(to right, #4f46e5, #9333ea); -fx-background-radius: 32 32 0 0;">
                        <padding><Insets left="35" right="35"/></padding>
                        <children>
                            <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="SkillPath Intelligence" textFill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 17;" />
                                    <Label text="Study Assistant • Llama 3.2" textFill="rgba(255,255,255,0.7)" style="-fx-font-size: 11; -fx-font-weight: 800;" />
                                </children>
                            </VBox>
                            <Button onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 28; -fx-cursor: hand; -fx-padding: 0;" text="×" />
                        </children>
                    </HBox>
                    
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="chatMessages" spacing="28" style="-fx-padding: 35; -fx-background-color: #0f172a;" />
                        </content>
                    </ScrollPane>

                    <VBox spacing="20" style="-fx-background-color: #1a2234; -fx-padding: 30; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 32 32;">
                        <children>
                            <HBox spacing="15" alignment="CENTER">
                                <children>
                                    <TextField fx:id="txtChatInput" promptText="Posez votre question sur ce module..." HBox.hgrow="ALWAYS" onAction="#sendChatMessage"
                                               style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-background-radius: 30; -fx-padding: 16 30; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 30;" />
                                    <Button onAction="#sendChatMessage" prefHeight="60" prefWidth="60" 
                                            style="-fx-background-color: #6366f1; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.5), 25, 0, 0, 10);">
                                        <graphic><Label text="➜" textFill="WHITE" style="-fx-font-size: 22; -fx-font-weight: bold;" /></graphic>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </VBox>

            <!-- Toggle Button -->
            <Button onAction="#toggleChat" prefHeight="85" prefWidth="85" 
                    style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #9333ea); -fx-background-radius: 45; -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.6), 40, 0, 0, 20); -fx-cursor: hand;">
                <graphic><Label text="💬" textFill="WHITE" style="-fx-font-size: 38;" /></graphic>
            </Button>
        </children>
    </VBox>
</AnchorPane>
